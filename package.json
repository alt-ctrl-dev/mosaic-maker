{
	"name": "mosaic-maker",
	"private": true,
	"packageManager": "pnpm@11.10.0",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "biome lint .",
		"format": "biome format .",
		"test": "vitest run",
		"typecheck": "tsc -b",
		"check": "pnpm run lint && pnpm run format && pnpm run test && pnpm run typecheck",
		"sandcastle": "pnpx tsx .sandcastle/main.mts",
		"sandcastle-playground": "pnpx tsx .sandcastle/playground.mts",
		"sandcastle-pr-creator": "pnpx tsx .sandcastle/pr-creator.mts",
		"prototype-neighbor-avoidance": "vite --config vite.prototype.config.ts",
		"prepare": "husky"
	},
	"dependencies": {
		"@picocss/pico": "^2.1.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@ai-hero/sandcastle": "^0.12.0",
		"@biomejs/biome": "^2.5.3",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^26.1.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.8",
		"typescript": "^6.0.3",
		"vite": "^8.1.3",
		"vitest": "^4.1.10"
	}
}
