{
  "name": "mosaic-maker",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "biome lint .",
    "format": "biome format .",
    "test": "vitest run",
    "typecheck": "tsc -b",
