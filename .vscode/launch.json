{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch sandcastle",
			"request": "launch",
			"runtimeArgs": ["sandcastle"],
			"runtimeExecutable": "pnpm",
			"skipFiles": ["<node_internals>/**"],
			"type": "node"
		},
		{
			"name": "Launch playground",
			"request": "launch",
			"runtimeArgs": ["sandcastle-playground"],
			"runtimeExecutable": "pnpm",
			"skipFiles": ["<node_internals>/**"],
			"type": "node"
		},
		{
			"name": "Create PR",
			"request": "launch",
			"runtimeArgs": ["sandcastle-pr-creator"],
			"runtimeExecutable": "pnpm",
			"skipFiles": ["<node_internals>/**"],
			"type": "node"
		}
	]
}
